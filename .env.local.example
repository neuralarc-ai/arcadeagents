# Copy to .env.local and fill in. All values are SERVER-SIDE ONLY.
# Never prefix with NEXT_PUBLIC_ and never commit .env.local.

# --- Stripe ---
# API key: test (sk_test_...) locally, live (sk_live_...) in production.
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret for the /api/webhook endpoint (whsec_...), one per endpoint.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# The recurring price to sell — $4.99 / year (price_...).
STRIPE_PRICE_ID=price_xxx

# --- License key generation ---
# HMAC secret. Arcade Agents' own secret; keep stable forever (changing it invalidates
# every previously issued key). Must eventually match the app-side validator's secret.
LICENSE_SECRET=change-me-to-a-long-random-secret

# --- Email (Resend) — optional ---
# If unset, the key is still issued/stored and shown on the success page; email is skipped.
RESEND_API_KEY=re_xxx
# From: address for the license email.
LICENSE_FROM_EMAIL=Arcade Agents <keys@arcadeagents.example>

# --- Site ---
# Base URL used to build success_url / cancel_url. No trailing slash.
SITE_URL=http://localhost:3000
